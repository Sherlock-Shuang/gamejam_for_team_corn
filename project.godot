; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="树独"
run/main_scene="res://scenes/ui/SplashScreen.tscn"
config/features=PackedStringArray("4.6", "4.6.1")
boot_splash/image="res://assets/队标2.png"
description="gamejam_for_team_corn project"

[audio]

buses/default_bus_layout="uid://c7rnj1ienaacn"
buses/channel_disable_time=0.0

[autoload]

SignalBus="*res://scripts/autoloads/SignalBus.gd"
GameData="*res://scripts/autoloads/GameData.gd"
PoolManager="*res://scripts/autoloads/PoolManager.gd"
AudioManager="*res://scripts/autoloads/AudioManager.gd"
UiSoundManager="*uid://duyq33175e1s1"

[display]

window/size/viewport_width=2560
window/size/viewport_height=1600
window/size/mode=3
window/size/borderless=true
window/size/window_width_override=1280
window/size/window_height_override=720
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/handheld/orientation=4

[gd_project]

config_version=4

[global_group]

Tree=""

[gui]

theme/custom_font="res://assets/fonts/朝华标题A.ttf"

[input_devices]

pointing/emulate_touch_from_mouse=true

[layer_names]

2d_render/layer_1="player"
2d_render/layer_2="enemy"
2d_render/layer_3="bullet"
2d_physics/layer_1="player"
2d_physics/layer_2="enemy"
2d_physics/layer_3="bullet"
2d_physics/layer_4="enemy_hitbox"
2d_physics/layer_5="player_hurtbox"
2d_physics/layer_6="world"

[physics]

2d/default_gravity=0.0
2d/default_gravity_vector=Vector2(0, 0)

[rendering]

textures/vram_compression/import_etc2_astc=true
